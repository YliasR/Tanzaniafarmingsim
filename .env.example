# SoilSMS Environment Variables

# AI Mode: "true" for local Ollama/Mistral, "false" for OpenRouter
USE_LOCAL_AI=true

# OpenRouter API (free tier available — get key at openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free

# Africa's Talking API (if SMS_MODE=africas_talking)
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=your_at_username

# SMS Mode: "modem" (local GSM) or "africas_talking" (gateway)
SMS_MODE=modem

# Farm Location (Tanzania default: -6.3, 34.8)
SERVER_LAT=-6.3
SERVER_LON=34.8

# Farmer's phone number to send advice to (e.g. +255XXXXXXXXX)
FARMER_PHONE=+255YYYYYYYYY

# GSM Serial Port (default /dev/ttyAMA0)
GSM_PORT=/dev/ttyAMA0
